AWS_REGION=us-east-1

# Option B (recommended): use a shared AWS CLI profile from ~/.aws/credentials
# AWS_PROFILE=default

# Option A: set access keys directly (not recommended to commit; keep in backend/.env)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
# AWS_SESSION_TOKEN=YOUR_AWS_SESSION_TOKEN

DDB_TABLE_NAME=Finsweet