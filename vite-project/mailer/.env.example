# Mailer server
MAILER_PORT=5001
# MAILER_HOST=0.0.0.0

# Note (macOS): port 5000 is often already used by the system (Control Center).
# If you see EADDRINUSE, use 5001 (default in code) or any free port.

# SMTP settings (example for common SMTP providers)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# If you use Gmail, create an App Password and use it as SMTP_PASS.
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_password

# Optional: explicit From address (defaults to SMTP_USER)
MAIL_FROM=your_email@example.com

# Where you (the site owner) will RECEIVE contact requests
MAIL_TO=gvika739@gmail.com
